# -----------------------------------------------------------------------
# Integration test environment variables
# -----------------------------------------------------------------------
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# -----------------------------------------------------------------------

# -----------------------------------------------------------------------
# Application under test
# -----------------------------------------------------------------------
QA_BASE_URL=https://your-app.qa.example.com

# -----------------------------------------------------------------------
# Auth - choose one strategy
# -----------------------------------------------------------------------

# Strategy 1: Static bearer token (preferred for pure API services)
# QA_API_TOKEN=your-api-token-here

# Strategy 2: Browser login (for apps with cookie/session auth)
# QA_USER_EMAIL=qa-user@example.com
# QA_USER_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------
# Login form selectors (used only when QA_API_TOKEN is not set)
# -----------------------------------------------------------------------
# QA_LOGIN_PATH=/login
# QA_LOGIN_EMAIL_SELECTOR=input[type="email"]
# QA_LOGIN_PASSWORD_SELECTOR=input[type="password"]
# QA_LOGIN_SUBMIT_SELECTOR=button[type="submit"]
# QA_LOGIN_SUCCESS_SELECTOR=.dashboard

# -----------------------------------------------------------------------
# Azure DevOps integration (optional)
# -----------------------------------------------------------------------
# ADO_ORG=your-org
# ADO_PROJECT=YourProject
# ADO_PLAN_ID=00000
# ADO_PAT=your-pat-here
# SYSTEM_ACCESSTOKEN=   # Set automatically in Azure Pipelines
